# Muse backend environment. Copy to backend/.env for local overrides.
MUSE_ENVIRONMENT=development
MUSE_DATA_ROOT=../local-data
MUSE_DATABASE_PATH=muse.sqlite3
MUSE_MEDIA_ROOT=media
MUSE_TEMP_UPLOAD_ROOT=tmp/uploads
MUSE_TEMP_PREVIEW_ROOT=tmp/previews
MUSE_ORIGINAL_IMAGE_ROOT=media/garments/original
MUSE_PROCESSED_IMAGE_ROOT=media/garments/processed
MUSE_THUMBNAIL_ROOT=media/garments/thumbnails
MUSE_CUTOUT_IMAGE_ROOT=media/garments/cutouts
MUSE_OUTFIT_PREVIEW_ROOT=media/outfits/previews
MUSE_BACKUP_ROOT=backups
MUSE_MAINTENANCE_ROOT=maintenance
MUSE_LOCK_ROOT=.locks
MUSE_MAX_BACKUP_ARCHIVE_BYTES=2147483648
MUSE_MAX_BACKUP_ENTRY_COUNT=20000
MUSE_MAX_BACKUP_COMPRESSION_RATIO=200
MUSE_MAINTENANCE_CLEANUP_BATCH_SIZE=100
MUSE_MAX_UPLOAD_SIZE_BYTES=26214400
MUSE_MAX_IMPORT_OVERHEAD_BYTES=65536
MUSE_UPLOAD_CHUNK_SIZE_BYTES=262144
MUSE_MAX_IMAGE_PIXELS=24000000
MUSE_MAX_IMAGE_DIMENSION=12000
MUSE_NORMALIZED_IMAGE_MAX_DIMENSION=1600
MUSE_THUMBNAIL_MAX_DIMENSION=384
MUSE_NORMALIZED_WEBP_QUALITY=85
MUSE_THUMBNAIL_WEBP_QUALITY=80
MUSE_BACKGROUND_PROCESSING_ENABLED=true
MUSE_BACKGROUND_PROCESSING_MAX_ATTEMPTS=2
MUSE_BACKGROUND_WORKER_POLL_SECONDS=0.5
MUSE_BACKGROUND_SHUTDOWN_TIMEOUT_SECONDS=10.0
MUSE_MAX_API_BODY_SIZE_BYTES=65536
MUSE_LOG_LEVEL=INFO
MUSE_FRONTEND_BUILD_PATH=../frontend/dist
MUSE_SERVE_FRONTEND=false
MUSE_TRUSTED_HOSTS=["127.0.0.1","localhost","testserver"]
MUSE_ALLOWED_ORIGINS=["http://127.0.0.1:5173","http://localhost:5173"]
MUSE_PHONE_UPLOAD_ENABLED=false
MUSE_PHONE_UPLOAD_BIND_HOST=127.0.0.1
MUSE_PHONE_UPLOAD_PORT=8787
# Set an advertised hostname only when it resolves from the intended phones.
# If this field is an IPv4 literal, it must equal the exact bind address.
# MUSE_PHONE_UPLOAD_ADVERTISED_HOST=muse.local
# For a physical phone, replace the bind host above and set this to that same stable private IPv4.
# MUSE_PHONE_UPLOAD_ADVERTISED_IPV4=192.168.1.50
MUSE_PHONE_UPLOAD_TRUSTED_HOSTS=["127.0.0.1","localhost","testserver"]
MUSE_PHONE_UPLOAD_FRONTEND_BUILD_PATH=../frontend/dist-phone
MUSE_PHONE_UPLOAD_SESSION_TTL_SECONDS=600
MUSE_PHONE_UPLOAD_MAX_ATTEMPTS=3
MUSE_PHONE_UPLOAD_RECEIVE_TIMEOUT_SECONDS=120
MUSE_PHONE_UPLOAD_CLEANUP_INTERVAL_SECONDS=300
MUSE_PHONE_UPLOAD_RETENTION_SECONDS=86400
MUSE_PHONE_UPLOAD_CLEANUP_BATCH_SIZE=100
MUSE_PHONE_UPLOAD_RATE_LIMIT_REQUESTS=60
MUSE_PHONE_UPLOAD_RATE_LIMIT_WINDOW_SECONDS=60
MUSE_PHONE_UPLOAD_RATE_LIMIT_CLIENTS=256
