# Muse backend environment. Copy to backend/.env for local overrides.
MUSE_ENVIRONMENT=development
MUSE_DATA_ROOT=../local-data
MUSE_DATABASE_PATH=muse.sqlite3
MUSE_MEDIA_ROOT=media
MUSE_TEMP_UPLOAD_ROOT=tmp/uploads
MUSE_ORIGINAL_IMAGE_ROOT=media/garments/original
MUSE_PROCESSED_IMAGE_ROOT=media/garments/processed
MUSE_THUMBNAIL_ROOT=media/garments/thumbnails
MUSE_OUTFIT_PREVIEW_ROOT=media/outfits/previews
MUSE_BACKUP_ROOT=backups
MUSE_MAX_UPLOAD_SIZE_BYTES=26214400
MUSE_MAX_API_BODY_SIZE_BYTES=65536
MUSE_LOG_LEVEL=INFO
MUSE_FRONTEND_BUILD_PATH=../frontend/dist
MUSE_SERVE_FRONTEND=false
MUSE_TRUSTED_HOSTS=["127.0.0.1","localhost","testserver"]
MUSE_ALLOWED_ORIGINS=["http://127.0.0.1:5173","http://localhost:5173"]
